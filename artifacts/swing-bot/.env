# ─────────────────────────────────────────────
#  STRUCT.ai Swing Engine — Configuration
# ─────────────────────────────────────────────
#  Fill in your MetaTrader 5 credentials below.
#  These are used only when SIMULATION_MODE=False
#  in config.py (i.e. live trading mode).
# ─────────────────────────────────────────────

# Your MT5 account number (the number you log in with)
MT5_LOGIN=

# Your MT5 account password
MT5_PASSWORD=

# Your broker's server name (find it in MT5 → File → Login → Server)
MT5_SERVER=

# MT5 symbol name for USDJPY on your broker (check exact spelling in MT5 Market Watch)
MT5_SYMBOL=USDJPYm

# URL of the News Impact Service (Repo 3) — leave default unless you changed the port
NEWS_IMPACT_URL=http://localhost:5003
